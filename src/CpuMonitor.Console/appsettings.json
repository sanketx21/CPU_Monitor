{
  "Monitor": {
    "IntervalSeconds": 5,
    "DiskRootPath": null
  },
  "FileLog": {
    "Enabled": true,
    "FilePath": "logs/monitor.log"
  },
  "Plugins": {
    "LoadExternalPlugins": true,
    "Directory": "Plugins"
  },
  "Api": {
    "Enabled": true,
    "EndpointUrl": "https://example.com/api/system-resources",
    "TimeoutSeconds": 10
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "System": "Warning"
    }
  }
}
